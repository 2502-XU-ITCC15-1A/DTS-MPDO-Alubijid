# Copy this file to .env and fill in your real credentials.

POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgresql://mpdo_user:your_postgres_password@mpdo-database:5432/mpdo_alubijid
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

VITE_SUPABASE_URL=https://your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=http://localhost:5000
VITE_PUBLIC_APP_URL=http://your-computer-ip-or-domain:8081
